{% extends 'base.html.twig' %}
{% block content %}

  <main>
    <div class="mx-auto max-w-7xl py-6 md:px-6 lg:px-8">
        <div class="bg-white shadow-md rounded-lg overflow-hidden">
          <div class="w-full">
            <table class="min-w-full divide-y divide-gray-200">
              <thead class="bg-gray-50">
                <tr>
                  <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                    {{ 'Vendor'|trans }}
                  </th>
                  <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                    {{ 'Type'|trans }}
                  </th>
                  <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                    {{ 'Color'|trans }}
                  </th>
                </tr>
              </thead>
              <tbody class="bg-white divide-y divide-gray-200">
                {% for filament in data %}
                <tr class="hover:bg-gray-100 cursor-pointer" onclick="window.location='/filament?{{ filament.f_id }}';">
                  <td class="px-6 py-4 whitespace-nowrap">
                    <!-- Vendor Name -->
                    <div class="text-sm text-gray-900">
                      {{ filament.name }}
                    </div>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <!-- Type Name -->
                    <div class="text-sm text-gray-900">
                      {{ filament.type_name }}
                    </div>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <!-- Color -->
                    <div class="text-sm text-gray-900 inline-table">
                      <span id="colorPreview" class="bg-[#{{ filament.colorhex }}] inline-block align-middle ring-2 ring-gray-500 ring-offset-1 rounded-full w-4 h-4 ml-2 -mt-1"></span> 
                    </div>
                    <div class="text-sm text-gray-900 inline-table">
                      {{ filament.color }}
                    </div>
                  </td>
                </tr>
                {% endfor %}
                <!-- Repeat the above row structure for each data entry -->
              </tbody>
            </table>
          </div>
        </div>
    </div>
  </main>
{% endblock %}