{% extends 'base.html.twig' %}
{% block content %}
  <main>
    <div class="mx-auto max-w-7xl py-6 md:px-6 lg:px-8">
          <div class="bg-white shadow-md rounded-lg overflow-hidden">
              <div class="flex">
                    <div class="w-1/4 hidden md:flex justify-center items-center p-2">
                        <img src="images/filaments/{{ filament.filament_image }}" alt="{{ filament.type_name }} {{ filament.color }}" class="w-fit max-h-80 object-cover">
                    </div>
                    <div class="w-full md:w-3/4 p-6">
                        <h1 class="text-3xl font-semibold mb-2"><img src="images/vendors/{{ filament.logo }}" alt="{{ filament.name }}" class="w-28 inline-block align-baseline"> {{ filament.type_name }}</h1>
                        <h2 class="text-2xl font-semibold mb-2">{{ 'Manufacturer information'|trans }}</h2>
                        <div class="flex items-center space-x-4 mb-4">
                        <table class="min-w-full leading-normal">
                            <tr>
                                <td class="md:w-1/3 py-2 px-2 border-b border-gray-200">{{ 'Color'|trans }}</td>
                                <td class="md:w-2/3 py-2 px-2 border-b border-gray-200">{{ filament.color }} - {{ filament.colorrgb }}
                                {% if filament.colorhex != null %} <span class="inline-block align-middle ring-2 ring-gray-500 ring-offset-1 rounded-full w-4 h-4 ml-2 bg-[#{{filament.colorhex}}]"></span> {% endif %}
                                
                                </td>
                            </tr>
                            <tr>
                                <td class="py-2 px-2 border-b border-gray-200">Durchmesser</td>
                                <td class="py-2 px-2 border-b border-gray-200">{{ filament.diameter }}mm ±{{ filament.diameter_variance }}mm</td>
                            </tr>
                            <tr>
                                <td class="py-2 px-2 border-b border-gray-200">
                                <ul class="relative">
                                <li>{{'Nozzle Temperatur'|trans }}<li>
                                    <ul>
                                    <div class="absolute left-2 bg-gray-500 bottom-6 rounded-sm top-6 w-[2px] h-[8px]"></div>
                                    <li class="relative flex">
                                        <span class="relative top-[0.3rem]">
                                        <svg class="absolute left-2 text-gray-500" width="12" height="11" viewBox="0 0 12 11" fill="none" aria-hidden="true"><path d="M11 9H4C2.89543 9 2 8.10457 2 7V1C2 0.447715 1.55228 0 1 0C0.447715 0 0 0.447715 0 1V7C0 9.20914 1.79086 11 4 11H11C11.5523 11 12 10.5523 12 10C12 9.44771 11.5523 9 11 9Z" fill="currentColor"></path></svg>
                                        </span>
                                        <div class="relative ml-6 py-[2px]">Empfohlene Temperatur</div>
                                    </li>
                                </ul>
                                </ul>
                                </td>
                                <td class="py-2 px-2 border-b border-gray-200">{{ filament.nozzletemp_low }}°C - {{ filament.nozzletemp_high }}°C<br/>
                                {{ filament.nozzletemp_sug }}°C</td>
                            </tr>
                            <tr>
                                <td class="py-2 px-2 border-b border-gray-200">
                                <ul class="relative">
                                <li>{{ 'Plate Temperatures'|trans }}<li>
                                    <ul>
                                    <div class="absolute left-2 bg-gray-500 bottom-6 rounded-sm top-6 w-[2px] h-[8px]"></div>
                                    <li class="relative flex">
                                        <span class="relative top-[0.3rem]">
                                        <svg class="absolute left-2 text-gray-500" width="12" height="11" viewBox="0 0 12 11" fill="none" aria-hidden="true"><path d="M11 9H4C2.89543 9 2 8.10457 2 7V1C2 0.447715 1.55228 0 1 0C0.447715 0 0 0.447715 0 1V7C0 9.20914 1.79086 11 4 11H11C11.5523 11 12 10.5523 12 10C12 9.44771 11.5523 9 11 9Z" fill="currentColor"></path></svg>
                                        </span>
                                        <div class="relative ml-6 py-[2px]">Empfohlene Temperatur</div>
                                    </li>
                                </ul>
                                </ul>
                                </td>
                                <td class="py-2 px-2 border-b border-gray-200">{{ filament.platetemp_low }}°C - {{ filament.platetemp_high }}°C<br/>
                                {{ filament.platetemp_sug }}°C</td>
                            </tr>
                            <tr>
                                <td class="py-2 px-2 border-b border-gray-200">Geschwindigkeit</td>
                                <td class="py-2 px-2 border-b border-gray-200">{{ filament.printspeed_low }}mm/s - {{ filament.printspeed_high }}mm/s</td>
                            </tr>
                        </table>
                        </div>
                        <div class="flex items-center space-x-4 mb-4">
                            <a href="{{ filament.productlink }}" target="_blank" class="px-4 py-2 bg-blue-500 text-white rounded-md hover:bg-blue-600">Herstellerseite <i class="fa-solid fa-link"></i></a>
                            {% if filament.amazonde != null %}
                            <a href="{{ filament.amazonde }}" target="_blank" class="px-4 py-2 bg-yellow-400 text-black rounded-md hover:bg-yellow-500">Amazon <i class="fa-brands fa-amazon"></i></a>
                            {% endif %}
                            <a href="images/qrcodes/{{ filament.f_id }}.png" download="{{ filament.f_id }}.png" class="px-4 py-2 bg-blue-500 text-white rounded-md hover:bg-blue-600" id="qrcode-download-link">Download <i class="fa-solid fa-qrcode"></i></a>
                        </div>
                        {#
                        <h2 class="text-2xl font-semibold mb-2">Templates (Json)</h2>
                        <div class="flex items-center space-x-4 mb-4">
                            <a href="#" class="px-4 py-2 bg-blue-500 text-white rounded-md hover:bg-blue-600">Bambulab <img src="images/bambu.png" class="w-4 h-4 inline-block align-baseline leading-none"></a>                            
                        </div>
                        #}
                  </div>
              </div>
          </div>
      </div>
  </main>
{% endblock %}