{% extends 'base.html.twig' %}
{% block content %}
<main>
    <div class="mx-auto max-w-7xl py-6 md:px-6 lg:px-8">
          <div class="bg-white border-gray-300 dark:border-gray-600 dark:bg-slate-700 shadow-md rounded-lg overflow-hidden">
            <div class="w-full h-14">
                <div class="h-14 min-w2full flex bg-gray-100 px-6 dark:bg-slate-600/75 dark:border-slate-50/[0.06] dark:text-red-500">
                    <div class="m-1 p-2">
                    <img src="images/vendors/{{ filament.logo }}" alt="{{ filament.name }}" style="vertical-align: -webkit-baseline-middle;" class="w-28 max-h-14 align-middle inline-block">
                    </div>
                    <div class="my-1 px-1 py-2 align-middle"><h1 class="text-3xl font-semibold">{{ filament.type_name }}</h1></div>
                </div>
                </div>
                <div class="flex">
                    <div class="w-1/4 hidden md:flex justify-center items-baseline p-2">
                        <div class="p-3 border rounded-lg">
                        <img src="images/filaments/{{ filament.filament_image }}" alt="{{ filament.type_name }} {{ filament.color }}" class="max-w-80 object-cover">
                        </div>
                    </div>
                    <div class="w-full md:w-3/4 p-6 dark:text-white">
                        <div>
                        <div class="flex space-x-2">
                            <button class="py-2 px-4 bg-gray-300 dark:bg-slate-800/75 dark:border-slate-50/[0.06] dark:text-red-500
                                        text-black hover:bg-gray-700 hover:text-white rounded-t-lg text-sm font-medium" data-tab="tab1">{{ 'Manufacturer information'|trans }}</button>
                            <button class="py-2 px-4 bg-gray-300 dark:bg-slate-800/75 dark:border-slate-50/[0.06] dark:text-red-500
                                        text-black hover:bg-gray-700 hover:text-white rounded-t-lg text-sm font-medium" data-tab="tab2">{{ 'Stores'|trans }}</button>
                            <button class="py-2 px-4 bg-gray-300 dark:bg-slate-800/75 dark:border-slate-50/[0.06] dark:text-red-500
                                        text-black hover:bg-gray-700 hover:text-white rounded-t-lg text-sm font-medium" data-tab="tab3">{{ 'Filamentprofiles'|trans }}</button>
                        </div>
                        </div>
                    <div class="tab-content border border-gray-200 p-1">
{# tab1 #}
                        <div class="tab-pane" id="tab1">
                            {# <h2 class="text-2xl font-semibold mb-2">{{ 'Manufacturer information'|trans }}</h2> #}
                        <div class="flex items-center space-x-4 mb-4">
                        <table class="min-w-full leading-normal dark:text-slate-300">
                            <tr>
                                <td class="md:w-1/3 py-2 px-2 border-b border-gray-200">{{ 'Color'|trans }}</td>
                                <td class="md:w-2/3 py-2 px-2 border-b border-gray-200">{{ filament.color }} - {{ filament.colorrgb }}
                                {% if filament.colorhex != null %} <span class="inline-block align-middle ring-2 ring-gray-500 dark:ring-gray-200 ring-offset-1 rounded-full w-4 h-4 ml-2 bg-[#{{filament.colorhex}}]"></span> {% endif %}
                                </td>
                            </tr>
                            <tr>
                                <td class="py-2 px-2 border-b border-gray-200">{{ 'Diameter'|trans }}</td>
                                <td class="py-2 px-2 border-b border-gray-200">{{ filament.diameter }}mm ±{{ filament.diameter_variance }}mm</td>
                            </tr>
                            <tr>
                                <td class="py-2 px-2 border-b border-gray-200">
                                <ul class="relative">
                                <li>{{'Nozzle Temperatur'|trans }}<li>
                                    <ul>
                                    <div class="absolute left-2 bg-gray-500 bottom-6 rounded-sm top-6 w-[2px] h-[8px]"></div>
                                    <li class="relative flex">
                                        <span class="relative top-[0.3rem]">
                                        <svg class="absolute left-2 text-gray-500" width="12" height="11" viewBox="0 0 12 11" fill="none" aria-hidden="true"><path d="M11 9H4C2.89543 9 2 8.10457 2 7V1C2 0.447715 1.55228 0 1 0C0.447715 0 0 0.447715 0 1V7C0 9.20914 1.79086 11 4 11H11C11.5523 11 12 10.5523 12 10C12 9.44771 11.5523 9 11 9Z" fill="currentColor"></path></svg>
                                        </span>
                                        <div class="relative ml-6 py-[2px]">{{ 'Suggested temperature'|trans }}</div>
                                    </li>
                                </ul>
                                </ul>
                                </td>
                                <td class="py-2 px-2 border-b border-gray-200">{{ filament.nozzletemp_low }}°C - {{ filament.nozzletemp_high }}°C<br/>
                                {{ filament.nozzletemp_sug }}°C</td>
                            </tr>
                            <tr>
                                <td class="py-2 px-2 border-b border-gray-200">
                                <ul class="relative">
                                <li>{{ 'Plate Temperatures'|trans }}<li>
                                    <ul>
                                    <div class="absolute left-2 bg-gray-500 bottom-6 rounded-sm top-6 w-[2px] h-[8px]"></div>
                                    <li class="relative flex">
                                        <span class="relative top-[0.3rem]">
                                        <svg class="absolute left-2 text-gray-500" width="12" height="11" viewBox="0 0 12 11" fill="none" aria-hidden="true"><path d="M11 9H4C2.89543 9 2 8.10457 2 7V1C2 0.447715 1.55228 0 1 0C0.447715 0 0 0.447715 0 1V7C0 9.20914 1.79086 11 4 11H11C11.5523 11 12 10.5523 12 10C12 9.44771 11.5523 9 11 9Z" fill="currentColor"></path></svg>
                                        </span>
                                        <div class="relative ml-6 py-[2px]">{{ 'Suggested temperature'|trans }}</div>
                                    </li>
                                </ul>
                                </ul>
                                </td>
                                <td class="py-2 px-2 border-b border-gray-200">{{ filament.platetemp_low }}°C - {{ filament.platetemp_high }}°C<br/>
                                {{ filament.platetemp_sug }}°C</td>
                            </tr>
                            <tr>
                                <td class="py-2 px-2 border-b border-gray-200">{{ 'Speed'|trans }}</td>
                                <td class="py-2 px-2 border-b border-gray-200">{{ filament.printspeed_low }}mm/s - {{ filament.printspeed_high }}mm/s</td>
                            </tr>
                        </table>
                        </div>
                        <div class="flex items-center space-x-2 mb-4">
                        {% if filament.productlink != '' %}
                            <a href="{{ filament.productlink }}" target="_blank" class="px-4 py-2 bg-blue-500 text-white rounded-md hover:bg-blue-600"><i class="fa-solid fa-link"></i> {{ 'Productwebsite'|trans }}</a>
                        {% endif %}
                            <a href="images/qrcodes/{{ filament.f_id }}.png" download="{{ filament.name|replace({" ": "_"}) }}_{{ filament.type_name|replace({" ": "_"}) }}_{{ filament.color|replace({" ": "_"}) }}_{{ filament.f_id }}.png"
                             class="px-4 py-2 bg-blue-500 text-white rounded-md hover:bg-blue-600" id="qrcode-download-link"><i class="fa-solid fa-qrcode"></i> {{ 'QRDownload'|trans }}</a>
                        </div>
                    </div>
{# tab2 #}
                    <div class="tab-pane hidden" id="tab2">
                    {#  <h2 class="text-2xl font-semibold mb-2">{{ 'Stores'|trans }}</h2> #}
                        {% if stores is not null and stores|length > 0 %}
                        <h3 class="text-lg font-semibold">{{ 'You can buy this Filament in those Stores'|trans }} <a href="/add/store?{{filament.f_id}}"><i class="fa-solid fa-plus"></i></a></h3>
                        <table class="min-w-full divide-y divide-gray-200">
                            <thead class="bg-gray-50 dark:bg-slate-800/75">
                                <tr>
                                    <th scope="col" class="border dark:border-slate-800/75 dark:text-white px-2 py-2 text-xs font-medium text-gray-500 uppercase tracking-wider w-fit">Country</th>
                                    <th scope="col" class="border dark:border-slate-800/75 dark:text-white px-2 py-2 text-xs font-medium text-gray-500 uppercase tracking-wider w-full">Store Links</th>
                                </tr>
                            </thead>
                                <tbody>
                                    {% set prevCountry = null %}
                                    {% for item in stores %}
                                        {% if item.website == 'Amazon' %}
                                            {% set bgcolor = 'bg-yellow-400 hover:bg-yellow-500' %}
                                        {% else %}
                                            {% set bgcolor = 'bg-blue-400 hover:bg-blue-500' %}
                                        {% endif %}
                                        {% if item.country != prevCountry %}
                                            {% if prevCountry is not null %}
                                                </td> <!-- Close the previous country's <td> -->
                                            </tr>
                                            {% endif %}
                                            <tr>
                                                <td class="border dark:border-slate-800/75 dark:bg-slate-800/75 dark:text-slate-300 px-2 py-1 whitespace-nowrap leading-10">{{ item.countryname }}</td>
                                                <td class="border dark:border-slate-800/75 dark:bg-slate-800/75 dark:text-slate-300 px-2 py-1 whitespace-nowrap leading-10">
                                                    <a href="{{ item.url }}" target="_blank" class="px-4 py-2 mr-2 {{ bgcolor }} text-black rounded-md">
                                                        {% if item.website == 'Amazon' %}
                                                            <i class="fa-brands fa-amazon"></i> 
                                                        {% else %}
                                                            <i class="fa-solid fa-link"></i> 
                                                        {% endif %}
                                                        {{ item.website }}
                                                    </a>
                                            {% else %}
                                                <a href="{{ item.url }}" target="_blank" class="px-4 py-2 mr-2 {{ bgcolor }} text-black rounded-md">
                                                    {% if item.website == 'Amazon' %}
                                                        <i class="fa-brands fa-amazon"></i> 
                                                    {% else %}
                                                        <i class="fa-solid fa-link"></i> 
                                                    {% endif %}
                                                    {{ item.website }}
                                                </a>
                                            {% endif %}
                                            {% set prevCountry = item.country %}
                                    {% endfor %}
                                    </td> <!-- Close the last country's <td> -->
                                    </tr>
                                </tbody>
                        </table>
                        {% else %}
                        <h3 class="text-lg font-semibold ">{{ 'Currently no Stores listed'|trans }} <a href="/add/store?{{filament.f_id}}"><i class="fa-solid fa-plus"></i></a></h3>
                        {% endif %}
                    </div>
{# tab3 #}
                    <div class="tab-pane hidden" id="tab3">
                        <h2 class="text-2xl font-semibold mb-2">{{ 'Printprofiles'|trans }}</h2>
                    
                    </div>

                    </div>
                </div>
              </div>
          </div>
    </div>
</main>

<script>
  const tabs = document.querySelectorAll("[data-tab]");
  tabs.forEach((tab) => {
    tab.addEventListener("click", () => {
      const tabId = tab.getAttribute("data-tab");
      const tabPanes = document.querySelectorAll(".tab-pane");
      tabPanes.forEach((pane) => {
        pane.classList.add("hidden");
      });
      document.getElementById(tabId).classList.remove("hidden");
    });
  });
</script>
{% endblock %}