<header class="bg-white shadow dark:border-gray-600 dark:bg-slate-700">
    <div class="py-2">
        <nav class="border border-b-1 flex border-gray-200 bg-white">
            <ol role="list" class="px-8 max-w-7xl w-full flex mx-auto space-x-4">
                <li class="flex">
                    <div class="items-center flex w-5 h-10">
                    <a class="text-gray-400 text-inherit" href="/">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="w-5 h-5 flex-shrink-0 text-gray-200"><path fill-rule="evenodd" d="M9.293 2.293a1 1 0 011.414 0l7 7A1 1 0 0117 11h-1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-3a1 1 0 00-1-1H9a1 1 0 00-1 1v3a1 1 0 01-1 1H5a1 1 0 01-1-1v-6H3a1 1 0 01-.707-1.707l7-7z" clip-rule="evenodd"></path></svg>
                        <span style="clip: rect(0, 0, 0, 0);white-space: nowrap;border-width: 0;width: 1px;height: 1px;margin: -1px;padding: 0;position: absolute;overflow: hidden;">Home</span>
                    </a>
                    </div>
                </li>
                {% if target == '' %}{% else %}
                {% for item in breadcrumb %}
                    <li class="flex">
                        <div class="items-center flex">
                            <svg class="h-full w-5 flex-shrink-0 text-gray-200" viewBox="0 0 24 44" preserveAspectRatio="none" fill="currentColor" aria-hidden="true"><path d="M.293 0l22 22-22 22h1.414l22-22-22-22H.293z"></path></svg>
                            <a class="text-gray-500 hover:text-gray-700 ml-4">{{ item|trans }}</a>
                        </div>
                    </li>
                {% endfor %}
                {% endif %}
            </ol>
        </nav>
    </div>
</header>
