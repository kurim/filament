{% extends 'base.html.twig' %}
{% block content %}
<main>
    <div class="mx-auto max-w-7xl py-6 md:px-6 lg:px-8">
        <div class="bg-white shadow-md rounded-lg overflow-hidden">
            <div class="w-full p-6">
            {{ 'You can buy this Filament in those Stores'|trans}}
                <div class="flex items-center space-x-4 mb-4">
                    {% for item in stores %}
                        {% if item.website == 'Amazon' %}
                        {% set bgcolor = 'bg-yellow-400 hover:bg-yellow-500' %}
                        {% else %}
                        {% set bgcolor = 'bg-blue-400 hover:bg-blue-500' %}
                        {% endif %}
                        <a href="{{ item.url }}" target="_blank" class="px-4 py-2 {{ bgcolor }} text-black rounded-md">
                        {{ item.website }} ({{ item.region }})
                        {% if item.website == 'Amazon' %}<i class="fa-brands fa-amazon"></i>
                        {% else %}<i class="fa-solid fa-link"></i>
                        {% endif %}
                        </a>
                        
                    {% endfor %}
                </div>

            </div>
        </div>
    </div>
</main>
{% endblock %}